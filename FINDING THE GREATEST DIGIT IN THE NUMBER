#include <stdio.h>
int main ()
{
    int n, digit, max=0;
    printf("Enter your number\n");
    scanf("%d",&n);
    int number=n;
    while(n>0)
    {
        digit = n % 10;
        if(digit > max)
        {
            max=digit;
        }
        n = n/10;
    }
    printf("The Greatest digit of number %d is\n%d",number, max);
}
