#include <stdio.h>
int main()
{
    double num1, num2;
    char operation;
    printf("Enter two numbers and the operator\n ");
    scanf("%lf %c %lf",&num1, &operation, &num2);
    if (operation=='+')
    {
       printf("%lf", num1+num2);
    }
    else if (operation=='-')
    {
        printf("%lf",num1-num2);
    }
    else if (operation=='*')
    {
        printf("%lf", num1*num2);
    }
    else if (operation=='/')
    {
        if (num2==0)
        {
            printf("invalid number ");
        }
        
        printf("%lf",num1/num2);
    }
}
