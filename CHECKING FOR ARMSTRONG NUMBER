#include <stdio.h>
int main()
{
    int n, sum = 0, digit;
    printf("Enter the number\n");
    scanf("%d",&n);
    int number = n;
    while(n > 0)
    {
        digit = n % 10;
        sum = sum + (digit*digit*digit);
        n = n / 10;
    }
    if (number == sum)
        printf("The number %d is Armstrong number\n ", number);
    else
        printf("The number %d is not a Armstrong number\n ", number);
    return 0;
}
