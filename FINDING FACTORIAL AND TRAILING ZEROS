#include <stdio.h>
int main()
{
    int n, i, divisor=5,count=0;
    printf("Enter the number\n ");
    scanf("%d",&n);
    int fact = 1;
    for (i = 1; i <= n; i++)
        {
         fact = fact * i ;
        }
        printf("The factorial of the number %d is \n%d\n", n,fact);
        while(divisor<=n)
        {
            count = count +(n/divisor);
            divisor=divisor*5;
        }
        printf("The trailing zeros in the factorial  is \n %d", count);
        return 0;
}
