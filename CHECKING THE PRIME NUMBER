#include <stdio.h>
int main()
{
    int n;
    printf("Enter the number\n");
    scanf("%d",&n);
    for(int i=2; i<n; i++)
    {
        if(n%i==0)
        {
            printf("the number is not a prime \n");
            return 0;
        }
    }
    printf("the number is prime");
    return 0;
}
